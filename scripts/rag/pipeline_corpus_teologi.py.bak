load_dotenv()

# ========== KONFIGURASI ==========
SUMBER_KATOLIK = r"D:\paroki_digital_stclemens\catholic source\referensi ajaran katolik\txt file"
SUMBER_IGNATIAN = r"D:\paroki_digital_stclemens\catholic source\referensi ignatian\txt file"
