# ========== EMBEDDING & NORMALISASI ==========
def normalize_embedding(vec):
    """Normalisasi embedding ke unit vector (magnitude = 1)"""
    import math
    magnitude = math.sqrt(sum(x * x for x in vec))
    if magnitude == 0:
        return vec
    return [x / magnitude for x in vec]

def embed_batch(texts):
    """Embed batch teks menggunakan Gemini"""
    genai.configure(api_key=next(key_pool))
    result = genai.embed_content(
        model=EMBEDDING_MODEL,
        content=texts,
        output_dimensionality=EMBEDDING_DIM
    )
    embeddings = result['embedding']
    return [normalize_embedding(e) for e in embeddings]

# ========== R2 UPLOAD ==========
def upload_ke_r2(r2_key, teks):
    """Upload teks ke R2, return preview"""
    r2.put_object(
        Bucket=R2_BUCKET,
        Key=r2_key,
        Body=teks.encode("utf-8"),
        ContentType="text/plain; charset=utf-8"
    )
    return teks[:R2_PREVIEW_LENGTH].strip()

# ========== CHUNKING ==========
def chunk_text(text, chunk_size=CHUNK_SIZE, overlap=OVERLAP):
    """Chunking berbasis kata dengan overlap"""
    words = text.split()
    chunks = []
    i = 0
    while i < len(words):
        chunk = ' '.join(words[i:i + chunk_size])
        chunks.append(chunk)
        i += chunk_size - overlap
    return chunks

# ========== UPLOAD KE COCKROACHDB ==========
def upload_chunks_rag_v6(chunks, embeddings, meta, doc_prefix):
    """Insert chunks ke theological_chunks + ai_knowledge_base"""
    cur = db_conn.cursor()
    
    for idx, (chunk, embedding) in enumerate(zip(chunks, embeddings)):
        chunk_uuid = str(uuid.uuid4())
        document_code = f"{doc_prefix}_{idx:04d}"
        
        # Upload ke R2 dulu
        r2_key = f"chunks/theological/{chunk_uuid}.txt"
        preview = upload_ke_r2(r2_key, chunk)
        
        # Insert ke theological_chunks
        # v6.5: cast ::vector diperlukan karena psycopg2 tidak punya adapter native
        cur.execute("""
            INSERT INTO theological_chunks
                (id, content_r2_key, content_preview, content_embedding,
                 chunk_source_domain, source_document, source_reference,
                 authority_level, embedding_outdated)
            VALUES (%s, %s, %s, %s::vector, %s, %s, %s, %s, %s)
        """, (
            chunk_uuid, r2_key, preview, str(embedding),
            "theology",
            meta["nama_dokumen"],
            f"{meta['nama_dokumen']} chunk {idx}",
            meta.get("authority_level", "medium"),
            False
        ))
        
        # Insert pointer ke ai_knowledge_base
        # v6.2: status = 'needs_review' (bukan 'approved') — harus melalui approval
        cur.execute("""
            INSERT INTO ai_knowledge_base
                (id, document_code, chunk_index, content_type, qa_pair_id,
                 chunk_table_ref, chunk_id, domain, bot_access, access_level_min,
                 question_type_classification, source_reference, nama_dokumen,
                 penulis, theology_topic, chunk_quality_score, status, expires_at)
            VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
        """, (
            str(uuid.uuid4()),
            document_code,
            idx,
            "rag_chunk",
            None,
            "theological_chunks",
            chunk_uuid,
            "theology",
            BOT_ACCESS_CORPUS_TEOLOGI,
            ACCESS_LEVEL_MIN,
            "spiritual_guidance",
            meta.get("nama_dokumen", ""),
            meta["nama_dokumen"],
            meta.get("penulis", ""),
            meta.get("theology_topic", []),
            4,
            "needs_review",
            None
        ))
    
    db_conn.commit()
    cur.close()

# ========== CHECKPOINT ==========
def load_checkpoint():
    """Load checkpoint untuk resume dari yang terakhir"""
    if Path(CHECKPOINT_FILE).exists():
        data = json.loads(Path(CHECKPOINT_FILE).read_text())
        return set(data.get("done_document_codes", []))
    return set()

def save_checkpoint(done):
    """Save checkpoint"""
    Path(CHECKPOINT_FILE).write_text(
        json.dumps({"done_document_codes": list(done)}, ensure_ascii=False, indent=2)
    )

# ========== PROSES SATU DOKUMEN ==========
def proses_dokumen(filepath, meta, done):
    """Proses satu dokumen: chunking, embedding, upload"""
    doc_prefix = meta["doc_prefix"]
    
    if doc_prefix in done:
        print(f"  ⏭  Skip (checkpoint): {meta['nama_dokumen']}")
        return 0
    
    if not filepath.exists():
        print(f"  ⚠️  File tidak ditemukan: {filepath.name}")
        return 0
    
    text = filepath.read_text(encoding='utf-8', errors='ignore')
    chunks = chunk_text(text)
    total = len(chunks)
    print(f"  📄 {meta['nama_dokumen']}: {total} chunks — mulai embed...")
    
    berhasil = 0
    for i in range(0, total, BATCH_SIZE):
        batch_chunks = chunks[i:i + BATCH_SIZE]
        try:
            embeddings = embed_batch(batch_chunks)
            upload_chunks_rag_v6(batch_chunks, embeddings, meta, doc_prefix)
            berhasil += len(batch_chunks)
            print(f"     ✅ Batch {i//BATCH_SIZE+1}/{(total-1)//BATCH_SIZE+1}: {len(batch_chunks)} chunks")
        except Exception as e:
            print(f"     ❌ Batch {i//BATCH_SIZE+1} error: {e}")
        time.sleep(0.5)  # Rate limiting
    
    done.add(doc_prefix)
    save_checkpoint(done)
    return berhasil

# ========== MAIN ==========
def main():
    print("=" * 60)
    print("pipeline_corpus_teologi.py — RAG v6.5")
    print(f"Target: theological_chunks + ai_knowledge_base (CockroachDB)")
    print(f"Embedding: {EMBEDDING_MODEL} ({EMBEDDING_DIM} dim)")
    print("=" * 60)
    
    done = load_checkpoint()
    total_ok = 0
    total_doc = 0
    
    print("\n📚 CORPUS KATOLIK")
    for filename, meta in METADATA_KATOLIK.items():
        filepath = Path(SUMBER_KATOLIK) / filename
        n = proses_dokumen(filepath, meta, done)
        total_ok += n
        total_doc += 1
    
    print("\n📚 CORPUS IGNATIAN")
    for filename, meta in METADATA_IGNATIAN.items():
        filepath = Path(SUMBER_IGNATIAN) / filename
        n = proses_dokumen(filepath, meta, done)
        total_ok += n
        total_doc += 1
    
    print("\n" + "=" * 60)
    print(f"✅ Selesai: {total_ok} chunks dari {total_doc} dokumen")
    print(f"   → theological_chunks: {total_ok} baris")
    print(f"   → ai_knowledge_base: {total_ok} baris (pointer metadata)")
    print("   ⚠️  JANGAN LUPA: Jalankan approve_corpus_teologi.py setelah review!")
    print("=" * 60)

if __name__ == "__main__":
    main()