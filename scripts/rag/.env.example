# ============================================
# SUPABASE - Auth + Tabel Aplikasi Non-RAG
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================
# COCKROACHDB - Seluruh Tabel RAG
# ============================================
COCKROACHDB_HOST=xxxxx.cockroachlabs.cloud
COCKROACHDB_PORT=26257
COCKROACHDB_DBNAME=defaultdb
COCKROACHDB_USER=xxxxx
COCKROACHDB_PASSWORD=xxxxx

# ============================================
# GEMINI AI - Embedding + Generate
# ============================================
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/gemini-embedding-2
EMBEDDING_DIMENSIONALITY=768

# Rotating API Keys Pool (untuk rate limit handling)
GOOGLE_API_KEY_1=AIza...
GOOGLE_API_KEY_2=AIza...
# Tambahkan sesuai kebutuhan (GOOGLE_API_KEY_3, dst)

# ============================================
# CLOUDFLARE R2 - Content Blob Store
# ============================================
R2_ACCOUNT_ID=xxxxx
R2_ACCESS_KEY_ID=xxxxx
R2_SECRET_ACCESS_KEY=xxxxx
R2_BUCKET_NAME=paroki-klemens-rag-content
